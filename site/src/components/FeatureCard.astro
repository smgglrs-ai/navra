---
interface Props {
  title: string;
  description: string;
  variant?: 'light' | 'dark';
}
const { title, description, variant = 'light' } = Astro.props;
---

<div class:list={['fcard', `fcard--${variant}`]}>
  <h3 class="fcard__title">{title}</h3>
  <p class="fcard__desc">{description}</p>
</div>

<style>
  .fcard {
    padding: 24px;
    border-radius: 8px;
    transition: border-color 0.15s;
  }
  .fcard--light {
    background: var(--white);
    border: 1px solid var(--border-light);
  }
  .fcard--light:hover { border-color: var(--coral); }
  .fcard--light .fcard__title { color: var(--navy); }
  .fcard--light .fcard__desc { color: var(--slate); }

  .fcard--dark {
    background: var(--navy-card);
    border: 1px solid var(--border);
  }
  .fcard--dark:hover { border-color: var(--coral); }
  .fcard--dark .fcard__title { color: var(--white); }
  .fcard--dark .fcard__desc { color: var(--muted); }

  .fcard__title {
    font-size: 1.125rem;
    font-weight: 600;
    margin-bottom: 8px;
    line-height: 1.3;
  }
  .fcard__desc {
    font-size: 0.8125rem;
    line-height: 1.6;
  }
</style>
