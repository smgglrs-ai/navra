# navra-agent distroless container image
#
# Security by construction: no shell, no coreutils, no package manager.
# The model's ONLY interface to the outside world is MCP tool calls
# through navra's permission/IFC/safety pipeline.
#
# The agent connects to a navra gateway (NAVRA_ENDPOINT) which enforces
# permissions, IFC labels, and safety filters. Filesystem access is
# provided by rust-mcp-filesystem running as a separate upstream MCP
# server managed by the gateway — never inside this container.
#
# Build:   podman build -f Dockerfile.agent -t navra-agent:latest .
# Run:     podman run --rm --network=slirp4netns:allow_host_loopback=true \
#            -e NAVRA_ENDPOINT=http://10.0.2.2:9400/mcp \
#            -e NAVRA_MODEL_ENDPOINT=http://10.0.2.2:8091/v1 \
#            -e NAVRA_MODEL_NAME=nemotron-omni \
#            -e NAVRA_TASK="Review the project" \
#            navra-agent:latest
#
# For the full image with ONNX Runtime, see Dockerfile.agent-full.

FROM registry.access.redhat.com/ubi10/ubi:latest AS builder

RUN dnf install -y gcc make rust cargo glibc-static && \
    dnf clean all

WORKDIR /src

# Copy only the crates navra-agent needs
COPY Cargo.toml Cargo.lock ./
COPY navra-agent/ navra-agent/
COPY navra-protocol/ navra-protocol/
COPY navra-model/ navra-model/
COPY navra-auth/ navra-auth/
COPY navra-safety/ navra-safety/
COPY navra-cognitive/ navra-cognitive/
COPY navra-responses/ navra-responses/
COPY navra-macros/ navra-macros/

# Stub out workspace members we didn't copy
RUN for dir in benchmarks navra-core navra-server navra-rag \
              navra-modal-voice navra-modal-vision navra-flow \
              navra-tools-exec navra-tools-file navra-tools-git \
              navra-tools-github navra-tools-gitlab \
              navra-model-hub navra-model-runtime navra-security \
              navra-memory; do \
      mkdir -p "$dir/src" && \
      printf '[package]\nname = "%s"\nversion = "0.0.0"\nedition = "2021"\n' \
        "$(basename $dir)" > "$dir/Cargo.toml" && \
      echo '' > "$dir/src/lib.rs"; \
    done

ENV RUSTFLAGS="-C target-feature=+crt-static"
RUN cargo build \
    --profile container \
    --bin navra-agent \
    --target x86_64-unknown-linux-gnu \
    --no-default-features \
    --features container

FROM scratch

COPY --from=builder /etc/pki/tls/certs/ca-bundle.crt /etc/ssl/certs/ca-certificates.crt

COPY --from=builder \
    /src/target/x86_64-unknown-linux-gnu/container/navra-agent \
    /usr/local/bin/navra-agent

USER 65534
ENTRYPOINT ["/usr/local/bin/navra-agent"]
